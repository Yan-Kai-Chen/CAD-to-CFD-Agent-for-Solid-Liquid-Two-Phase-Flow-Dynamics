{
  "schema_version": "fromcad2cfd_solidworks_plan_v1",
  "project": "phase7_cfd_templates",
  "model_name": "phase7_perforated_plate_channel",
  "description": "CFD template: perforated plate or baffle with repeated through holes.",
  "document": {
    "type": "part",
    "save_part": true,
    "export_step": true,
    "close_document": true
  },
  "execution": {
    "stop_on_error": true,
    "visible": false
  },
  "operations": [
    {
      "id": "plate_body",
      "op": "create_rectangular_prism",
      "args": {
        "width_mm": 72.0,
        "height_mm": 36.0,
        "depth_mm": 8.0,
        "merge_result": true
      }
    },
    {
      "id": "hole_array",
      "op": "cut_hole_grid",
      "args": {
        "radius_mm": 2.2,
        "centers_mm": [
          [
            -24.0,
            -6.0
          ],
          [
            -8.0,
            -6.0
          ],
          [
            8.0,
            -6.0
          ],
          [
            24.0,
            -6.0
          ],
          [
            -24.0,
            6.0
          ],
          [
            -8.0,
            6.0
          ],
          [
            8.0,
            6.0
          ],
          [
            24.0,
            6.0
          ]
        ],
        "through_all": true
      }
    },
    {
      "id": "edge_chamfer",
      "op": "apply_all_edge_chamfer",
      "args": {
        "distance_mm": 0.5,
        "angle_deg": 45.0
      }
    }
  ],
  "template": {
    "template_version": "fromcad2cfd_cfd_templates_v1",
    "template_name": "perforated-plate-channel",
    "parameters": {
      "columns": 4,
      "rows": 2,
